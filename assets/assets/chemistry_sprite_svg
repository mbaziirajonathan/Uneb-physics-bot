<svg xmlns="http://www.w3.org/2000/svg" style="display:none">
  <defs>
    <style>.label{font-size:10px;fill:black;font-family:Arial}</style>
    <!-- 1. APPARATUS: Bunsen Burner S1 -->
    <symbol id="bunsen_burner" viewBox="0 0 100 120"><rect x="40" y="20" width="20" height="80" fill="gray" stroke="black"/><ellipse cx="50" cy="100" rx="20" ry="10" fill="black"/><path d="M50,20 Q60,5 50,0 Q40,5 50,20" fill="orange"/><text x="15" y="110" class="label">Bunsen Burner</text></symbol>
    <!-- 2. ATOMIC STRUCTURE: Bohr Model S2 -->
    <symbol id="atom" viewBox="0 0 120 120"><circle cx="60" cy="60" r="8" fill="red"/><circle cx="60" cy="60" r="25" fill="none" stroke="blue"/><circle cx="60" cy="60" r="40" fill="none" stroke="blue"/><circle cx="60" cy="35" r="4" fill="blue"/><circle cx="60" cy="20" r="4" fill="blue"/><text x="35" y="110" class="label">Atomic Structure</text></symbol>
    <!-- 3. TITRATION SETUP S2 -->
    <symbol id="titration" viewBox="0 0 120 140"><rect x="50" y="10" width="5" height="80" fill="gray"/><rect x="20" y="90" width="60" height="30" fill="white" stroke="black"/><ellipse cx="50" cy="50" rx="15" ry="40" fill="none" stroke="black"/><path d="M50,10 L50,0" stroke="black"/><text x="25" y="135" class="label">Titration Setup</text></symbol>
    <!-- 4. BONDING: Water Molecule S3 -->
    <symbol id="water_molecule" viewBox="0 0 120 80"><circle cx="60" cy="40" r="12" fill="red"/><text x="57" y="45" class="label" fill="white">O</text><circle cx="30" cy="20" r="8" fill="gray"/><text x="28" y="24" class="label" fill="white">H</text><circle cx="90" cy="20" r="8" fill="gray"/><text x="88" y="24" class="label" fill="white">H</text><line x1="38" y1="28" x2="52" y2="35" stroke="black" stroke-width="2"/><line x1="82" y1="28" x2="68" y2="35" stroke="black" stroke-width="2"/></symbol>
    <!-- 5. ORGANIC: Alkane Chain S4 -->
    <symbol id="alkane" viewBox="0 0 150 60"><circle cx="20" cy="30" r="8" fill="black"/><circle cx="50" cy="30" r="8" fill="black"/><circle cx="80" cy="30" r="8" fill="black"/><circle cx="110" cy="30" r="8" fill="black"/><line x1="28" y1="30" x2="42" y2="30" stroke="black" stroke-width="3"/><line x1="58" y1="30" x2="72" y2="30" stroke="black" stroke-width="3"/><line x1="88" y1="30" x2="102" y2="30" stroke="black" stroke-width="3"/><text x="40" y="50" class="label">Alkane Chain</text></symbol>
  </defs>
</svg>
